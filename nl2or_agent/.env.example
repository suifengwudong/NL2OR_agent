# ── LLM 配置 ──────────────────────────────────────────────────────────────
# HAMLET 使用 litellm，支持 OpenAI / DeepSeek / 通义千问 等，通过下面的变量切换
HAMLET_MODEL_ID=deepseek/deepseek-chat   # 例: openai/gpt-4o, openai/gpt-5-mini

# 填入对应提供商的 API Key
OPEN_ROUTER_API_KEY=sk-or-xxx

# 其他提供商示例（如需使用可取消注释并填写对应 Key）
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1  # 如有代理可取消注释

# ── 工作区 ────────────────────────────────────────────────────────────────
# 生成的代码、中间表示等的存储根目录
NL2OR_WORKSPACE_DIR=./workspace

# ── Gurobi（可选）─────────────────────────────────────────────────────────
# 若使用 Gurobi 许可证，填写下面的路径；社区版自动检测，无需配置
# GRB_LICENSE_FILE=/path/to/gurobi.lic

# ── 可观测性（可选）──────────────────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
